# --- App ---
APP_NAME="Finance AI Agent"
ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/finance_ai_agent

# --- Security ---
SECRET_KEY=change-me-in-production

# --- Clerk (Authentication) ---
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_JWKS_URL=

# --- AI Providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- Logging ---
LOG_LEVEL=INFO

# --- n8n Automation ---
N8N_WEBHOOK_SECRET=
