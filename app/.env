# Finance AI Agent - Server Environment
ENVIRONMENT=development
DEBUG=true

# API Configuration
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=true

# Database (SQLite for local development)
DATABASE_URL=sqlite+aiosqlite:///./finance_ai.db

# Clerk Auth (stub - replace with real keys)
CLERK_SECRET_KEY=sk_test_placeholder
CLERK_PUBLISHABLE_KEY=pk_test_placeholder

# LLM Providers
OPENAI_API_KEY=sk_test_placeholder
ANTHROPIC_API_KEY=sk_test_placeholder
LLM_PROVIDER=openai

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Feature Flags
ENABLE_AGENTS=true
ENABLE_WEBHOOKS=false
